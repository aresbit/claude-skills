meta =
  name = fetch-skill
  version = 1

title = fetch-skill

skill =
  name = fetch-skill
  description =
    统一 URL 内容抓取器。自动识别 URL 类型，路由到最佳后端，输出干净的 Markdown / JSON / 纯文本。
    零依赖核心（普通网页 + 单条推文仅用 Python stdlib），Camofox / wechat-article-exporter 为可选增强。
  entry = SKILL.spcl
  refs =
    = reference/*.spcl
  extras =
    = scripts/fetch.py
    = program.md

content =
  capabilities =
    matrix =
      url_type = 普通网页
      auto_detect = ✅
      backend = Jina Reader → defuddle.md → markdown.new → Raw
      extra_deps = 无
    matrix =
      url_type = X/Twitter 单条推文
      auto_detect = ✅
      backend = FxTwitter API（`api.fxtwitter.com`）
      extra_deps = 无（零依赖）
    matrix =
      url_type = X/Twitter 回复
      auto_detect = `--replies`
      backend = Camofox + Nitter
      extra_deps = Camofox（本地 9377）
    matrix =
      url_type = X/Twitter 用户时间线
      auto_detect = `--user`
      backend = Camofox + Nitter
      extra_deps = Camofox
    matrix =
      url_type = X Article（长文）
      auto_detect = ✅
      backend = Camofox → Jina 兜底
      extra_deps = 推荐 Camofox
    matrix =
      url_type = 微信公众号文章
      auto_detect = ✅
      backend = wechat-article-exporter API → Jina → defuddle → Raw
      extra_deps = 可选 API

  quick_start =
    command =
      = SKILL=~/.claude/skills/fetch-skill/scripts/fetch.py
    example =
      description = 抓取任意网页（自动选最佳策略）
      command = python3 $SKILL https://example.com
    example =
      description = 保存到文件
      command = python3 $SKILL https://example.com -o output.md
    example =
      description = 静默抓取（不输出进度）
      command = python3 $SKILL https://example.com -q
    example =
      description = 人类可读的纯文本输出
      command = python3 $SKILL https://example.com -t
    example =
      description = 强制跳过 Jina，直接用 defuddle.md
      command = python3 $SKILL https://example.com --no-jina
    x_twitter =
      example =
        description = 单条推文（无需登录，无需 API Key）
        command = python3 $SKILL https://x.com/OpenAI/status/123456 -t
      example =
        description = 推文 JSON 完整数据
        command = python3 $SKILL https://x.com/OpenAI/status/123456 --pretty
      example =
        description = 推文 + 回复（需要 Camofox）
        command = python3 $SKILL https://x.com/OpenAI/status/123456 --replies -t
      example =
        description = 用户时间线，最多 100 条（需要 Camofox）
        command = python3 $SKILL https://x.com/elonmusk --user elonmusk --limit 100 -t
      example =
        description = 用户时间线（无 URL）
        command = python3 $SKILL --user elonmusk --limit 100
    wechat =
      example =
        description = Jina 兜底（无需额外配置）
        command = python3 $SKILL "https://mp.weixin.qq.com/s/xxxx"
      example =
        description = 使用本地 wechat-article-exporter 服务
        command = python3 $SKILL "https://mp.weixin.qq.com/s/xxxx" --wechat-api http://localhost:3000
      example =
        description = 通过环境变量
        command = WECHAT_API_URL=http://localhost:3000 python3 $SKILL "https://mp.weixin.qq.com/s/xxxx"

  full_options =
    usage = python3 fetch.py [url] [选项]
    positional =
      url = 目标 URL（与 --user 二选一）
    general =
      option = -o, --output FILE
        description = 保存到文件（默认 stdout）
      option = -m, --mode auto|web|twitter|wechat
        description = 强制模式（默认 auto）
      option = --timeout N
        description = HTTP 超时秒数（默认 30）
      option = -v, --verbose
        description = 显示详细进度（默认开启）
      option = -q, --quiet
        description = 不输出进度
    web =
      option = --no-jina
        description = 跳过 Jina Reader，直接从 defuddle.md 开始
    x_twitter =
      option = -r, --replies
        description = 抓取回复（需 Camofox）
      option = --user USERNAME
        description = 抓取用户时间线（需 Camofox）
      option = --limit N
        description = 时间线最大条数（默认 50）
      option = --pretty
        description = JSON 缩进输出
      option = -t, --text-only
        description = 人类可读输出（而非 JSON）
      option = --port PORT
        description = Camofox 端口（默认 9377）
      option = --lang zh|en
        description = 提示语言（默认 zh）
    wechat =
      option = --wechat-api URL
        description = wechat-article-exporter API 地址

  environment_variables =
    variable = WECHAT_API_URL
      description = wechat-article-exporter 部署地址，如 `http://localhost:3000`

  fallback_chains =
    general_web =
      step = Jina Reader (r.jina.ai)  ← 最佳 Markdown 质量
      step = defuddle.md
      step = markdown.new
      step = Raw HTML
    wechat_article =
      step = wechat-article-exporter API（若 WECHAT_API_URL 已配置）
      step = Jina Reader
      step = defuddle.md
      step = Raw HTML
    single_tweet =
      step = FxTwitter /{user}/status/{id}
      step = FxTwitter /status/{id}
      step = Jina Reader（网页回退）
    note = 进度和错误 → **stderr**，内容 → **stdout**，方便管道使用。

  camofox_installation =
    description = 回复/时间线/X Article 功能需要 [Camofox](https://github.com/ythx-101/x-tweet-fetcher)（本地 Firefox 反检测自动化服务）。
    method =
      name = 方式 1：OpenClaw 插件
      command = openclaw plugins install @askjo/camofox-browser
    method =
      name = 方式 2：手动
      command = git clone https://github.com/ythx-101/camofox
      command = cd camofox && npm install && npm start
      note = 默认监听 localhost:9377
    note = 未安装 Camofox 时，以下功能完全可用：单条推文、微信文章（Jina）、任意网页。

  wechat_article_exporter_local_deployment =
    command = docker run -p 3000:3000 ghcr.io/wechat-article/wechat-article-exporter:latest
    usage = WECHAT_API_URL=http://localhost:3000 python3 fetch.py "https://mp.weixin.qq.com/s/xxxx"
    documentation = 详细文档：https://docs.mptext.top

  related_projects =
    project =
      name = x-tweet-fetcher
      url = https://github.com/ythx-101/x-tweet-fetcher
      description = 推特抓取后端参考，含 Camofox 集成
    project =
      name = wechat-article-exporter
      url = https://github.com/wechat-article/wechat-article-exporter
      description = 微信文章批量导出服务
    project =
      name = kenmick/skills web-fetcher
      url = https://github.com/kenmick/skills
      description = 原始通用网页回退链设计来源
    project =
      name = FxTwitter API (`api.fxtwitter.com`)
      description = 零依赖公开推文数据源

resolve =
  merge = deep
  conflict = right-bias
  fixpoint = true
  max_iter = 64
